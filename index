<!DOCTYPE html>
<html lang="ru">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1, maximum-scale=1">
<title>Brick Buro · Авторский надзор</title>
<link rel="manifest" href="manifest.json">
<meta name="theme-color" content="#1C1C1C">
<meta name="apple-mobile-web-app-capable" content="yes">
<meta name="apple-mobile-web-app-status-bar-style" content="black">
<meta name="apple-mobile-web-app-title" content="АС Надзор">
<link rel="apple-touch-icon" href="icon.png">
<script src="https://cdn.jsdelivr.net/npm/@supabase/supabase-js@2/dist/umd/supabase.min.js"></script>
<style>
* { box-sizing: border-box; margin: 0; padding: 0; }
:root { --dark:#1C1C1C; --brick:#B85C3A; --brick-light:#F5EDE8; --warm:#F7F4F0; --rule:#D4C8BD; --muted:#888076; --mid:#3A3A3A; }
body { font-family:-apple-system,Arial,sans-serif; background:var(--warm); min-height:100vh; }
.app { max-width:680px; margin:0 auto; display:flex; flex-direction:column; min-height:100vh; }

/* AUTH */
.auth-wrap { flex:1; display:flex; align-items:center; justify-content:center; padding:20px; }
.auth-card { background:white; border:0.5px solid var(--rule); padding:32px; width:100%; max-width:380px; }
.auth-logo { display:flex; align-items:center; gap:10px; margin-bottom:28px; }
.auth-logo-icon { width:32px; height:32px; background:var(--dark); display:flex; align-items:center; justify-content:center; }
.auth-logo-text { font-size:13px; font-weight:700; letter-spacing:0.14em; text-transform:uppercase; color:var(--dark); }
.auth-logo-sub { font-size:10px; color:var(--muted); margin-top:1px; }
.auth-title { font-size:18px; font-weight:600; color:var(--dark); margin-bottom:6px; }
.auth-sub { font-size:13px; color:var(--muted); margin-bottom:24px; line-height:1.5; }
.auth-field { display:flex; flex-direction:column; gap:5px; margin-bottom:14px; }
.auth-label { font-size:10px; font-weight:700; letter-spacing:0.08em; text-transform:uppercase; color:var(--muted); }
.auth-input { border:0.5px solid var(--rule); padding:11px 13px; font-size:14px; color:var(--dark); outline:none; width:100%; font-family:inherit; }
.auth-input:focus { border-color:var(--brick); }
.auth-btn { background:var(--brick); color:white; border:none; padding:12px; font-size:14px; font-weight:600; width:100%; cursor:pointer; font-family:inherit; margin-top:6px; }
.auth-btn:hover { background:#9a4a2c; }
.auth-btn:disabled { opacity:0.6; }
.auth-switch { text-align:center; margin-top:16px; font-size:13px; color:var(--muted); }
.auth-switch a { color:var(--brick); cursor:pointer; text-decoration:none; }
.auth-err { background:#FFF0EB; border-left:3px solid var(--brick); padding:10px 12px; font-size:12px; color:#B85C3A; margin-bottom:14px; line-height:1.5; display:none; }
.auth-err.show { display:block; }

/* HEADER */
.hdr { background:var(--dark); padding:12px 16px; display:flex; align-items:center; gap:10px; }
.hdr-icon { width:22px; height:22px; background:var(--brick); display:flex; align-items:center; justify-content:center; }
.hdr-word { font-size:11px; font-weight:700; letter-spacing:0.16em; text-transform:uppercase; color:white; }
.hdr-right { font-size:11px; color:rgba(255,255,255,0.4); margin-left:auto; display:flex; align-items:center; gap:12px; }
.logout-btn { background:none; border:none; color:rgba(255,255,255,0.45); font-size:11px; cursor:pointer; font-family:inherit; }
.logout-btn:hover { color:white; }

/* VISITS */
.pg { flex:1; padding:16px; }
.top-row { display:flex; align-items:center; justify-content:space-between; margin-bottom:16px; }
.h1 { font-size:20px; font-weight:600; color:var(--dark); }
.btn-p { background:var(--brick); color:white; border:none; padding:9px 16px; font-size:13px; font-weight:600; cursor:pointer; font-family:inherit; }
.vcard { background:white; border:0.5px solid var(--rule); padding:14px; margin-bottom:8px; cursor:pointer; position:relative; }
.vcard:hover { border-color:var(--brick); }
.vname { font-size:14px; font-weight:600; color:var(--dark); margin-bottom:3px; }
.vmeta { font-size:11px; color:var(--muted); }
.varr { position:absolute; right:14px; top:50%; transform:translateY(-50%); color:var(--muted); }
.empty { text-align:center; padding:40px 20px; color:var(--muted); font-size:13px; }
.loading { text-align:center; padding:40px 20px; color:var(--muted); font-size:13px; }

/* VISIT */
.vpage { flex:1; display:flex; flex-direction:column; }
.vhdr { background:var(--dark); padding:12px 16px; display:flex; align-items:center; gap:10px; }
.backb { color:rgba(255,255,255,0.6); font-size:12px; cursor:pointer; background:none; border:none; font-family:inherit; white-space:nowrap; }
.vtitle { flex:1; font-size:13px; font-weight:600; color:white; overflow:hidden; text-overflow:ellipsis; white-space:nowrap; }
.saveb { background:var(--brick); color:white; border:none; padding:7px 14px; font-size:12px; font-weight:600; cursor:pointer; font-family:inherit; }
.tabs { display:flex; background:white; border-bottom:1.5px solid var(--rule); overflow-x:auto; }
.tab { flex:1; min-width:55px; padding:10px 6px; font-size:11px; font-weight:600; border:none; background:none; color:var(--muted); border-bottom:2px solid transparent; margin-bottom:-1.5px; cursor:pointer; white-space:nowrap; font-family:inherit; }
.tab.on { color:var(--brick); border-bottom-color:var(--brick); }
.body { flex:1; padding:14px; }
.sec { display:flex; flex-direction:column; gap:12px; }
.fld { display:flex; flex-direction:column; gap:4px; }
.lbl { font-size:10px; font-weight:700; letter-spacing:0.08em; text-transform:uppercase; color:var(--muted); }
.inp { border:0.5px solid var(--rule); background:white; padding:9px 11px; font-size:13px; color:var(--dark); outline:none; width:100%; font-family:inherit; }
.inp:focus { border-color:var(--brick); }
.txa { border:0.5px solid var(--rule); background:white; padding:9px 11px; font-size:13px; color:var(--dark); resize:vertical; min-height:80px; outline:none; width:100%; line-height:1.5; font-family:inherit; }
.txa:focus { border-color:var(--brick); }
.r2 { display:grid; grid-template-columns:1fr 1fr; gap:10px; }
.cnts { display:flex; gap:14px; font-size:12px; color:var(--muted); }
.cnts b { color:var(--dark); }
.arow { display:flex; gap:8px; }
.ainp { flex:1; border:0.5px solid var(--rule); background:white; padding:9px 11px; font-size:13px; color:var(--dark); outline:none; font-family:inherit; }
.ainp:focus { border-color:var(--brick); }
.abtn { background:var(--dark); color:white; border:none; width:38px; font-size:18px; cursor:pointer; }
.trow { display:flex; align-items:center; gap:8px; padding:9px 11px; background:white; border:0.5px solid var(--rule); margin-bottom:4px; }
.trow.dn { opacity:0.5; }
.chk { width:16px; height:16px; border:1.5px solid var(--rule); flex-shrink:0; cursor:pointer; }
.chk.on { background:var(--brick); border-color:var(--brick); }
.ttxt { flex:1; font-size:13px; }
.trow.dn .ttxt { text-decoration:line-through; }
.db { background:none; border:none; font-size:16px; color:var(--muted); cursor:pointer; padding:0 3px; }
.aobs { background:var(--dark); color:white; border:none; padding:11px; font-size:13px; font-weight:600; width:100%; cursor:pointer; margin-bottom:10px; font-family:inherit; }
.ogrid { display:grid; grid-template-columns:1fr 1fr; gap:10px; }
.ocard { background:white; border:0.5px solid var(--rule); }
.oph { width:100%; height:120px; background:var(--warm); display:flex; align-items:center; justify-content:center; font-size:11px; color:var(--muted); position:relative; overflow:hidden; cursor:pointer; text-align:center; padding:8px; }
.oph img { width:100%; height:100%; object-fit:cover; display:block; }
.oplbl { position:absolute; bottom:4px; font-size:9px; background:rgba(0,0,0,0.45); color:white; padding:2px 7px; }
.ocats { padding:6px 8px 3px; display:flex; gap:3px; flex-wrap:wrap; }
.cat { font-size:10px; font-weight:700; padding:2px 6px; background:var(--warm); color:var(--muted); cursor:pointer; border:none; font-family:inherit; }
.onote { margin:3px 8px 4px; border:0.5px solid var(--rule); padding:5px 7px; font-size:11px; resize:none; color:var(--dark); outline:none; width:calc(100% - 16px); font-family:inherit; }
.odel { background:none; border:none; font-size:10px; color:var(--muted); padding:0 8px 6px; cursor:pointer; display:block; font-family:inherit; }
.sgrid { display:grid; grid-template-columns:1fr 1fr 1fr; gap:8px; margin-bottom:14px; }
.sc { background:white; border:0.5px solid var(--rule); padding:10px; text-align:center; }
.sl { font-size:10px; color:var(--muted); margin-bottom:3px; }
.sv { font-size:22px; font-weight:700; color:var(--dark); }
.bbtn { background:var(--brick); color:white; border:none; padding:11px; font-size:13px; font-weight:600; width:100%; cursor:pointer; margin-bottom:10px; font-family:inherit; }
.bbtn:hover { background:#9a4a2c; }
.hint { background:var(--brick-light); border-left:3px solid var(--brick); padding:10px 12px; font-size:12px; color:var(--mid); line-height:1.6; margin-bottom:10px; }

/* PDF */
@media print {
  body { background:white !important; }
  .no-print { display:none !important; }
}
.pdf-page { background:white; width:100%; font-family:Arial,sans-serif; color:#1C1C1C; }
.pdf-hdr { background:#1C1C1C; padding:24px 28px 20px; }
.pdf-hdr-top { display:flex; justify-content:space-between; align-items:flex-start; margin-bottom:18px; }
.pdf-logo-mark { display:flex; align-items:center; gap:9px; margin-bottom:3px; }
.pdf-logo-sq { width:24px; height:24px; background:#B85C3A; display:flex; align-items:center; justify-content:center; }
.pdf-logo-name { font-size:12px; font-weight:700; letter-spacing:0.16em; text-transform:uppercase; color:white; }
.pdf-logo-tag { font-size:9px; color:rgba(255,255,255,0.4); padding-left:33px; }
.pdf-doc-type { font-size:9px; color:#B85C3A; text-align:right; letter-spacing:0.08em; text-transform:uppercase; margin-bottom:3px; }
.pdf-doc-num { font-size:10px; color:rgba(255,255,255,0.45); text-align:right; }
.pdf-visit-title { font-size:20px; color:white; margin-bottom:14px; font-weight:400; }
.pdf-meta { display:flex; border-top:0.5px solid rgba(255,255,255,0.12); padding-top:12px; }
.pdf-meta-item { flex:1; padding-right:14px; }
.pdf-meta-item+.pdf-meta-item { border-left:0.5px solid rgba(255,255,255,0.12); padding-left:14px; }
.pdf-meta-lbl { font-size:8px; color:rgba(255,255,255,0.35); text-transform:uppercase; letter-spacing:0.08em; margin-bottom:3px; }
.pdf-meta-val { font-size:11px; color:rgba(255,255,255,0.85); }
.pdf-body { padding:22px 28px; }
.pdf-section { margin-bottom:22px; page-break-inside:avoid; }
.pdf-sec-head { display:flex; align-items:center; gap:9px; margin-bottom:12px; }
.pdf-sec-num { width:20px; height:20px; background:#B85C3A; color:white; font-size:9px; font-weight:700; display:flex; align-items:center; justify-content:center; flex-shrink:0; }
.pdf-sec-title { font-size:8px; font-weight:700; letter-spacing:0.14em; text-transform:uppercase; color:#888076; }
.pdf-sec-line { flex:1; height:0.5px; background:#D4C8BD; }
.pdf-task { display:flex; align-items:flex-start; gap:9px; padding:7px 0; border-bottom:0.5px solid #F0EAE3; font-size:12px; }
.pdf-task:last-child { border:none; }
.pdf-task-chk { width:13px; height:13px; flex-shrink:0; margin-top:1px; }
.pdf-task-chk.done { background:#B85C3A; }
.pdf-task-chk.open { border:1.5px solid #D4C8BD; }
.pdf-task-text { flex:1; line-height:1.5; }
.pdf-task-text.done { color:#999; text-decoration:line-through; }
.pdf-badge { font-size:9px; font-weight:700; padding:2px 7px; flex-shrink:0; }
.pdf-badge-done { background:#F5EDE8; color:#B85C3A; }
.pdf-badge-next { background:#F0EDE8; color:#888076; }
.pdf-obs-grid { display:grid; grid-template-columns:1fr 1fr; gap:10px; }
.pdf-obs-card { border:0.5px solid #E8E0D6; page-break-inside:avoid; }
.pdf-obs-photo { width:100%; height:110px; object-fit:cover; display:block; background:#F7F4F0; }
.pdf-obs-photo-empty { width:100%; height:110px; background:#F0EBE5; display:flex; align-items:center; justify-content:center; font-size:11px; color:#bbb; }
.pdf-obs-info { padding:7px 9px; }
.pdf-obs-cat { font-size:8px; font-weight:700; letter-spacing:0.08em; text-transform:uppercase; margin-bottom:3px; }
.pdf-obs-note { font-size:10px; color:#3A3A3A; line-height:1.5; }
.pdf-proto-item { padding:8px 0; border-bottom:0.5px solid #F0EAE3; }
.pdf-proto-item:last-child { border:none; }
.pdf-proto-lbl { font-size:8px; font-weight:700; letter-spacing:0.1em; text-transform:uppercase; color:#888076; margin-bottom:4px; }
.pdf-proto-text { font-size:12px; color:#1C1C1C; line-height:1.6; white-space:pre-wrap; }
.pdf-sign-row { display:grid; grid-template-columns:1fr 1fr 1fr; gap:20px; margin-top:24px; padding-top:18px; border-top:0.5px solid #D4C8BD; }
.pdf-sign-line { height:0.5px; background:#1C1C1C; margin-bottom:5px; }
.pdf-sign-name { font-size:10px; color:#1C1C1C; margin-bottom:2px; }
.pdf-sign-role { font-size:9px; color:#888076; }
.pdf-footer { background:#1C1C1C; padding:10px 28px; display:flex; justify-content:space-between; align-items:center; }
.pdf-footer-brand { display:flex; align-items:center; gap:6px; }
.pdf-footer-dot { width:5px; height:5px; background:#B85C3A; }
.pdf-footer-name { font-size:9px; letter-spacing:0.1em; text-transform:uppercase; color:rgba(255,255,255,0.45); }
.pdf-footer-mid { font-size:9px; color:rgba(255,255,255,0.3); }
.pdf-footer-pg { font-size:9px; color:rgba(255,255,255,0.4); }
</style>
