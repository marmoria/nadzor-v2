<body>
<div class="app" id="app"><div class="loading" style="padding:40px;text-align:center">Загрузка...</div></div>
<script>
const SUPABASE_URL = 'https://pjrvjlpjyfvlkobzkhtp.supabase.co'
const SUPABASE_KEY = 'eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZSIsInJlZiI6InBqcnZqbHBqeWZ2bGtvYnpraHRwIiwicm9sZSI6ImFub24iLCJpYXQiOjE3NzM0MjQ2NzksImV4cCI6MjA4OTAwMDY3OX0.hGPjFpMQ7n_xh-XE9qIINFpSPiOrK-zgYn_qY5TPDnY'
const sb = supabase.createClient(SUPABASE_URL, SUPABASE_KEY)

const CATS = [
  {id:'defect',label:'Дефект',color:'#B85C3A'},
  {id:'ok',label:'Принято',color:'#5A8A6A'},
  {id:'note',label:'Заметка',color:'#8A7A5A'},
  {id:'question',label:'Вопрос',color:'#5A6A8A'}
]

let S = {user:null, screen:'visits', visits:[], cid:null, tab:'meta', visit:null, tasks:[], obs:[], proto:{}}

function e(s){if(!s)return'';return String(s).replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/"/g,'&quot;');}
function fd(d){if(!d)return'—';try{return new Date(d).toLocaleDateString('ru-RU',{day:'numeric',month:'long',year:'numeric'});}catch(x){return d;}}
function tod(){return new Date().toISOString().split('T')[0];}
function $(id){return document.getElementById(id)}

// ===== AUTH =====
async function init(){
  const {data:{session}} = await sb.auth.getSession()
  if(session){S.user=session.user; await loadVisits()}
  else showAuth('login')

  sb.auth.onAuthStateChange(async(event,session)=>{
    if(event==='SIGNED_IN'&&session){S.user=session.user; await loadVisits()}
    if(event==='SIGNED_OUT'){S.user=null; showAuth('login')}
  })
}

function showAuth(mode){
  const isLogin = mode==='login'
  $('app').innerHTML = `
  <div class="auth-wrap">
    <div class="auth-card">
      <div class="auth-logo">
        <div class="auth-logo-icon">
          <svg width="16" height="16" viewBox="0 0 14 14" fill="none">
            <rect x="1" y="4" width="12" height="4" fill="white" opacity="0.9"/>
            <rect x="1" y="9" width="5.5" height="4" fill="white" opacity="0.6"/>
            <rect x="7.5" y="9" width="5.5" height="4" fill="white" opacity="0.6"/>
          </svg>
        </div>
        <div>
          <div class="auth-logo-text">Brick Buro</div>
          <div class="auth-logo-sub">Авторский надзор</div>
        </div>
      </div>
      <div class="auth-title">${isLogin?'Вход':'Регистрация'}</div>
      <div class="auth-sub">${isLogin?'Войдите чтобы продолжить работу':'Создайте аккаунт для вашей команды'}</div>
      <div class="auth-err" id="auth-err"></div>
      <div class="auth-field">
        <div class="auth-label">Email</div>
        <input class="auth-input" id="auth-email" type="email" placeholder="you@example.com" autocomplete="email">
      </div>
      <div class="auth-field">
        <div class="auth-label">Пароль</div>
        <input class="auth-input" id="auth-pass" type="password" placeholder="Минимум 6 символов" autocomplete="${isLogin?'current-password':'new-password'}"
          onkeydown="if(event.key==='Enter')${isLogin?'doLogin()':'doRegister()}"}">
      </div>
      <button class="auth-btn" id="auth-btn" onclick="${isLogin?'doLogin()':'doRegister()'}">${isLogin?'Войти':'Создать аккаунт'}</button>
      <div class="auth-switch">
        ${isLogin?'Нет аккаунта? <a onclick="showAuth(\'register\')">Зарегистрироваться</a>':'Уже есть аккаунт? <a onclick="showAuth(\'login\')">Войти</a>'}
      </div>
    </div>
  </div>`
}

async function doLogin(){
  const email=$('auth-email')?.value.trim()
  const pass=$('auth-pass')?.value
  if(!email||!pass){showErr('Заполните все поля');return}
  setAuthLoading(true)
  const {error} = await sb.auth.signInWithPassword({email,password:pass})
  if(error){showErr(getErrMsg(error));setAuthLoading(false)}
}

async function doRegister(){
  const email=$('auth-email')?.value.trim()
  const pass=$('auth-pass')?.value
  if(!email||!pass){showErr('Заполните все поля');return}
  if(pass.length<6){showErr('Пароль минимум 6 символов');return}
  setAuthLoading(true)
  const {error} = await sb.auth.signUp({email,password:pass})
  if(error){showErr(getErrMsg(error));setAuthLoading(false)}
  else{showErr('Проверьте почту — мы отправили ссылку для подтверждения.',true);setAuthLoading(false)}
}

async function doLogout(){
  await sb.auth.signOut()
}

function showErr(msg, isInfo=false){
  const el=$('auth-err')
  if(!el)return
  el.textContent=msg
  el.style.display='block'
  el.style.background=isInfo?'#E8F5E8':''
  el.style.color=isInfo?'#2E7D32':''
  el.style.borderLeftColor=isInfo?'#5A8A6A':''
}

function setAuthLoading(on){
  const btn=$('auth-btn')
  if(btn){btn.disabled=on;btn.textContent=on?'Подождите...':btn.textContent}
}

function getErrMsg(error){
  if(error.message.includes('Invalid login'))return'Неверный email или пароль'
  if(error.message.includes('Email not confirmed'))return'Подтвердите email — проверьте почту'
  if(error.message.includes('already registered'))return'Этот email уже зарегистрирован'
  if(error.message.includes('Password should'))return'Пароль минимум 6 символов'
  return error.message
}

// ===== VISITS =====
async function loadVisits(){
  $('app').innerHTML = renderHdr() + '<div class="pg"><div class="loading">Загрузка...</div></div>'
  const {data,error} = await sb.from('visits').select('*')
    .eq('user_id', S.user.id)
    .order('created_at',{ascending:false})
  S.visits = data||[]
  S.screen='visits'
  render()
}

function renderHdr(){
  const email = S.user?.email||''
  const short = email.split('@')[0]
  return `<div class="hdr no-print">
    <div class="hdr-icon"><svg width="12" height="12" viewBox="0 0 14 14" fill="none">
      <rect x="1" y="4" width="12" height="4" fill="white" opacity="0.9"/>
      <rect x="1" y="9" width="5.5" height="4" fill="white" opacity="0.6"/>
      <rect x="7.5" y="9" width="5.5" height="4" fill="white" opacity="0.6"/>
    </svg></div>
    <div class="hdr-word">Brick Buro</div>
    <div class="hdr-right">
      <span style="display:none;font-size:10px">${e(short)}</span>
      <button class="logout-btn" onclick="doLogout()">Выйти</button>
    </div>
  </div>`
}

function render(){
  $('app').innerHTML = S.screen==='visits' ? rV() : rVis()
}

function rV(){
  const cards = S.visits.length===0
    ? '<div class="empty">Нажмите «+ Новый визит» чтобы начать</div>'
    : S.visits.map(v=>`<div class="vcard" onclick="openV('${v.id}')">
        <div class="vname">${e(v.object_name)||'Без названия'}</div>
        <div class="vmeta">Визит №${v.visit_number} · ${e(v.visit_date)||'—'} · ${e(v.author)||'—'}</div>
        <div class="varr">→</div>
      </div>`).join('')
  return renderHdr()+`<div class="pg">
    <div class="top-row"><div class="h1">Визиты</div>
    <button class="btn-p" onclick="createV()">+ Новый визит</button></div>
    ${cards}
  </div>`
}

async function createV(){
  const {data,error} = await sb.from('visits').insert({
    user_id: S.user.id,
    object_name:'', visit_number:S.visits.length+1,
    visit_date:tod(), author:'', stage:''
  }).select().single()
  if(error){alert('Ошибка: '+error.message);return}
  await openV(data.id)
}

async function openV(id){
  S.cid=id; S.screen='visit'; S.tab='meta'
  $('app').innerHTML = '<div class="loading" style="padding:40px;text-align:center">Загрузка...</div>'
  const [{data:v},{data:tasks},{data:obs},{data:proto}] = await Promise.all([
    sb.from('visits').select('*').eq('id',id).single(),
    sb.from('tasks').select('*').eq('visit_id',id).order('created_at'),
    sb.from('observations').select('*').eq('visit_id',id).order('sort_order'),
    sb.from('protocol').select('*').eq('visit_id',id).maybeSingle()
  ])
  S.visit=v||{}; S.tasks=tasks||[]; S.obs=obs||[]
  S.proto=proto||{attendees:'',discussed:'',agreed:'',next_visit:''}
  render()
}

function rVis(){
  const v=S.visit||{}
  const TB=[['meta','Объект'],['tasks','Задачи'],['obs','Фото'],['proto','Протокол'],['rep','Отчёт']]
  const th=TB.map(([k,l])=>`<button class="tab ${S.tab===k?'on':''}" onclick="sT('${k}')">${l}</button>`).join('')
  let b=''
  if(S.tab==='meta')b=tMeta(v)
  else if(S.tab==='tasks')b=tTask()
  else if(S.tab==='obs')b=tObs()
  else if(S.tab==='proto')b=tProto()
  else if(S.tab==='rep')b=tRep(v)
  return `<div class="vhdr no-print">
    <button class="backb" onclick="bk()">← Визиты</button>
    <div class="vtitle">${e(v.object_name)||'Новый визит'}</div>
    <button class="saveb" id="sb" onclick="saveV()">Сохранить</button>
  </div>
  <div class="vpage">
    <div class="tabs no-print">${th}</div>
    <div class="body"><div class="sec">${b}</div></div>
  </div>`
}

function tMeta(v){return `
  <div class="fld"><div class="lbl">Название объекта</div>
    <input class="inp" id="f-obj" value="${e(v.object_name)}" placeholder="Введите название объекта"></div>
  <div class="r2">
    <div class="fld"><div class="lbl">Номер визита</div>
      <input class="inp" id="f-num" type="number" value="${v.visit_number||1}"></div>
    <div class="fld"><div class="lbl">Дата</div>
      <input class="inp" id="f-date" type="date" value="${e(v.visit_date)}"></div>
  </div>
  <div class="fld"><div class="lbl">Автор надзора</div>
    <input class="inp" id="f-auth" value="${e(v.author)}" placeholder="ФИО, должность"></div>
  <div class="fld"><div class="lbl">Этап строительства</div>
    <input class="inp" id="f-stage" value="${e(v.stage)}" placeholder="Например: отделочные работы"></div>`
}

async function saveV(){
  const btn=$('sb'); if(btn)btn.textContent='Сохраняю...'
  const obj=$('f-obj')?.value||'', num=+$('f-num')?.value||1
  const date=$('f-date')?.value||'', auth=$('f-auth')?.value||'', stage=$('f-stage')?.value||''
  await sb.from('visits').update({object_name:obj,visit_number:num,visit_date:date,author:auth,stage}).eq('id',S.cid)
  const att=$('f-att')?.value, disc=$('f-disc')?.value, agr=$('f-agr')?.value, nxt=$('f-nxt')?.value
  if(att!==undefined){
    await sb.from('protocol').upsert({visit_id:S.cid,attendees:att,discussed:disc,agreed:agr,next_visit:nxt},{onConflict:'visit_id'})
    S.proto={attendees:att,discussed:disc,agreed:agr,next_visit:nxt}
  }
  S.visit={...S.visit,object_name:obj,visit_number:num,visit_date:date,author:auth,stage}
  if(btn){btn.textContent='Сохранено!';setTimeout(()=>btn.textContent='Сохранить',1500)}
}

async function bk(){S.screen='visits'; await loadVisits();}
function sT(t){S.tab=t;render();}

function tTask(){
  const dn=S.tasks.filter(t=>t.done).length, op=S.tasks.filter(t=>!t.done).length
  const rows=S.tasks.map((t,i)=>`
    <div class="trow ${t.done?'dn':''}">
      <div class="chk ${t.done?'on':''}" onclick="togT('${t.id}',${i})"></div>
      <span class="ttxt">${e(t.text)}</span>
      <button class="db" onclick="delT('${t.id}',${i})">×</button>
    </div>`).join('')
  return `<div class="cnts"><span>Выполнено: <b>${dn}</b></span><span>Открыто: <b>${op}</b></span></div>
    <div class="arow"><input class="ainp" id="nt" placeholder="Добавить задачу..." onkeydown="if(event.key==='Enter')aT()">
    <button class="abtn" onclick="aT()">+</button></div>${rows}`
}

async function aT(){
  const i=$('nt'); if(!i||!i.value.trim())return
  const {data,error}=await sb.from('tasks').insert({visit_id:S.cid,text:i.value.trim(),done:false}).select().single()
  if(!error){S.tasks.push(data);i.value='';render();setTimeout(()=>{const el=$('nt');if(el)el.focus()},30)}
}
async function togT(id,i){const done=!S.tasks[i].done;await sb.from('tasks').update({done}).eq('id',id);S.tasks[i].done=done;render();}
async function delT(id,i){await sb.from('tasks').delete().eq('id',id);S.tasks.splice(i,1);render();}

function tObs(){
  const cards=S.obs.map((o,i)=>`
    <div class="ocard">
      <div class="oph" onclick="trP(${i})">${o.photo_url?`<img src="${o.photo_url}">`:'<span>нажмите —<br>добавить фото</span>'}
        <span class="oplbl">фото ${i+1}</span></div>
      <div class="ocats">${CATS.map(c=>`<button class="cat" style="${o.category===c.id?`background:${c.color};color:white`:''}" onclick="sCat('${o.id}',${i},'${c.id}')">${c.label}</button>`).join('')}</div>
      <textarea class="onote" rows="2" placeholder="Описание..." oninput="sNote('${o.id}',${i},this.value)">${e(o.note)}</textarea>
      <button class="odel" onclick="delO('${o.id}',${i})">удалить</button>
    </div>`).join('')
  return `<button class="aobs" onclick="aO()">+ Добавить наблюдение</button>
    <input type="file" id="phi" accept="image/*" capture="environment" style="display:none" onchange="hPhoto(event)">
    <div class="ogrid">${cards}</div>`
}

let pi=null
async function aO(){
  const {data,error}=await sb.from('observations').insert({visit_id:S.cid,category:'defect',note:'',sort_order:S.obs.length}).select().single()
  if(!error){S.obs.push(data);render()}
}
function trP(i){pi=i;$('phi').click();}
async function hPhoto(ev){
  const f=ev.target.files[0]; if(!f||pi===null)return
  const o=S.obs[pi]
  const path=`${S.user.id}/${S.cid}/${Date.now()}.jpg`
  const {error:upErr}=await sb.storage.from('site-photos').upload(path,f,{contentType:'image/jpeg'})
  let url=null
  if(!upErr){const {data:{publicUrl}}=sb.storage.from('site-photos').getPublicUrl(path);url=publicUrl}
  else{const r=new FileReader();r.onload=async e2=>{url=e2.target.result;await sb.from('observations').update({photo_url:url}).eq('id',o.id);S.obs[pi].photo_url=url;render();};r.readAsDataURL(f);ev.target.value='';return}
  await sb.from('observations').update({photo_url:url}).eq('id',o.id)
  S.obs[pi].photo_url=url; ev.target.value=''; render()
}
async function sCat(id,i,cat){await sb.from('observations').update({category:cat}).eq('id',id);S.obs[i].category=cat;render();}
async function sNote(id,i,val){S.obs[i].note=val;clearTimeout(window._nt);window._nt=setTimeout(()=>sb.from('observations').update({note:val}).eq('id',id),800);}
async function delO(id,i){await sb.from('observations').delete().eq('id',id);S.obs.splice(i,1);render();}

function tProto(){
  const p=S.proto||{}
  return `
  <div class="fld"><div class="lbl">Участники совещания</div>
    <input class="inp" id="f-att" value="${e(p.attendees)}" placeholder="Иванова А.С. (архитектор), Петров В.И. (прораб)..."></div>
  <div class="fld"><div class="lbl">Обсудили</div>
    <textarea class="txa" id="f-disc" placeholder="Перечислите вопросы...">${e(p.discussed)}</textarea></div>
  <div class="fld"><div class="lbl">Договорились</div>
    <textarea class="txa" id="f-agr" placeholder="Зафиксируйте решения...">${e(p.agreed)}</textarea></div>
  <div class="fld"><div class="lbl">Вопросы на следующий визит</div>
    <textarea class="txa" id="f-nxt" placeholder="Что проверить / уточнить...">${e(p.next_visit)}</textarea></div>
  <button class="bbtn" onclick="saveV()">Сохранить протокол</button>`
}

function tRep(v){
  const dn=S.tasks.filter(t=>t.done),op=S.tasks.filter(t=>!t.done)
  const cC={defect:'#B85C3A',ok:'#5A8A6A',note:'#8A7A5A',question:'#5A6A8A'}
  const cL={defect:'Дефект',ok:'Принято',note:'Заметка',question:'Вопрос'}
  const yr=new Date().getFullYear(),nm=String(v.visit_number||1).padStart(3,'0')
  const p=S.proto||{}
  const tr=[...dn.map(t=>`<div class="pdf-task"><div class="pdf-task-chk done"></div><span class="pdf-task-text done">${e(t.text)}</span><span class="pdf-badge pdf-badge-done">Выполнено</span></div>`),...op.map(t=>`<div class="pdf-task"><div class="pdf-task-chk open"></div><span class="pdf-task-text">${e(t.text)}</span><span class="pdf-badge pdf-badge-next">Визит №${(v.visit_number||0)+1}</span></div>`)].join('')
  const oc=S.obs.map(o=>`<div class="pdf-obs-card">${o.photo_url?`<img class="pdf-obs-photo" src="${o.photo_url}">`:'<div class="pdf-obs-photo-empty">нет фото</div>'}<div class="pdf-obs-info"><div class="pdf-obs-cat" style="color:${cC[o.category]||'#888'}">${cL[o.category]||o.category}</div><div class="pdf-obs-note">${e(o.note)||'—'}</div></div></div>`).join('')
  return `
  <div class="sgrid no-print">
    <div class="sc"><div class="sl">Выполнено</div><div class="sv">${dn.length}</div></div>
    <div class="sc"><div class="sl">Открыто</div><div class="sv">${op.length}</div></div>
    <div class="sc"><div class="sl">Замечаний</div><div class="sv">${S.obs.length}</div></div>
  </div>
  <div class="hint no-print">Нажмите «Скачать PDF» → выберите «Сохранить как PDF» → включите «Фоновая графика».</div>
  <button class="bbtn no-print" onclick="printPdf()">Скачать PDF</button>
  <div class="pdf-page">
    <div class="pdf-hdr">
      <div class="pdf-hdr-top">
        <div><div class="pdf-logo-mark"><div class="pdf-logo-sq"><svg width="12" height="12" viewBox="0 0 14 14" fill="none"><rect x="1" y="4" width="12" height="4" fill="white" opacity="0.9"/><rect x="1" y="9" width="5.5" height="4" fill="white" opacity="0.6"/><rect x="7.5" y="9" width="5.5" height="4" fill="white" opacity="0.6"/></svg></div><div class="pdf-logo-name">Brick Buro</div></div><div class="pdf-logo-tag">дизайн коммерческих интерьеров · Санкт-Петербург</div></div>
        <div><div class="pdf-doc-type">Журнал авт. сопровождения</div><div class="pdf-doc-num">№ АС-${yr}-${nm}</div></div>
      </div>
      <div class="pdf-visit-title">${e(v.object_name)||'Объект'} — Визит № ${v.visit_number||1}</div>
      <div class="pdf-meta">
        <div class="pdf-meta-item"><div class="pdf-meta-lbl">Дата визита</div><div class="pdf-meta-val">${fd(v.visit_date)}</div></div>
        <div class="pdf-meta-item"><div class="pdf-meta-lbl">Автор надзора</div><div class="pdf-meta-val">${e(v.author)||'—'}</div></div>
        <div class="pdf-meta-item"><div class="pdf-meta-lbl">Этап</div><div class="pdf-meta-val">${e(v.stage)||'—'}</div></div>
      </div>
    </div>
    <div class="pdf-body">
      ${S.tasks.length?`<div class="pdf-section"><div class="pdf-sec-head"><div class="pdf-sec-num">01</div><div class="pdf-sec-title">Выполнение плановых задач</div><div class="pdf-sec-line"></div></div>${tr}</div>`:''}
      ${S.obs.length?`<div class="pdf-section"><div class="pdf-sec-head"><div class="pdf-sec-num">02</div><div class="pdf-sec-title">Замечания и фиксация на объекте</div><div class="pdf-sec-line"></div></div><div class="pdf-obs-grid">${oc}</div></div>`:''}
      ${p.discussed||p.agr?`<div class="pdf-section"><div class="pdf-sec-head"><div class="pdf-sec-num">03</div><div class="pdf-sec-title">Протокол совещания на объекте</div><div class="pdf-sec-line"></div></div>${p.attendees?`<div class="pdf-proto-item"><div class="pdf-proto-lbl">Участники</div><div class="pdf-proto-text">${e(p.attendees)}</div></div>`:''}${p.discussed?`<div class="pdf-proto-item"><div class="pdf-proto-lbl">Обсудили</div><div class="pdf-proto-text">${e(p.discussed)}</div></div>`:''}${p.agreed?`<div class="pdf-proto-item"><div class="pdf-proto-lbl">Договорились</div><div class="pdf-proto-text">${e(p.agreed)}</div></div>`:''}${p.next_visit?`<div class="pdf-proto-item"><div class="pdf-proto-lbl">На следующий визит</div><div class="pdf-proto-text">${e(p.next_visit)}</div></div>`:''}</div>`:''}
      <div class="pdf-sign-row">
        <div><div class="pdf-sign-line"></div><div class="pdf-sign-name">${e(v.author)||'________________'}</div><div class="pdf-sign-role">Архитектор / авт. надзор</div></div>
        <div><div class="pdf-sign-line"></div><div class="pdf-sign-name">________________</div><div class="pdf-sign-role">Прораб</div></div>
        <div><div class="pdf-sign-line"></div><div class="pdf-sign-name">________________</div><div class="pdf-sign-role">Заказчик</div></div>
      </div>
    </div>
    <div class="pdf-footer">
      <div class="pdf-footer-brand"><div class="pdf-footer-dot"></div><div class="pdf-footer-name">Brick Buro</div></div>
      <div class="pdf-footer-mid">Журнал авт. сопровождения · ${e(v.object_name)} · Визит № ${v.visit_number||1} · ${fd(v.visit_date)}</div>
      <div class="pdf-footer-pg">стр. 1</div>
    </div>
  </div>`
}

function printPdf(){
  const v=S.visit||{}
  document.title='BrickBuro_АС_'+(v.object_name||'vizit')+'_визит'+(v.visit_number||1)
  window.print()
}

init()
</script>
</body>
</html>
